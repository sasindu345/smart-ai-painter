APP_NAME=Smart AI Painter API
API_V1_PREFIX=/api/v1
SECRET_KEY=your-secret-key-here

# AI Generation Mode: local_diffusers | replicate | mock
AI_MODE=local_diffusers
# URL to local GPU diffusers server (e.g. Google Colab + Ngrok tunnel)
LOCAL_DIFFUSERS_URL=https://your-ngrok-tunnel.ngrok-free.app

# Vision Language Model (VLM) — analyzes sketch before generating
# Primary: gemini | Fallback: groq
VLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Groq VLM (auto-fallback if Gemini fails)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.2-11b-vision-preview

# Neon Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
